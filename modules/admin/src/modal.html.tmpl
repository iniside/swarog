<!-- Modal fragment (no page shell). Rendered for GET /admin/{slug}?partial=modal on an
     htmx request; swapped into #modal-root. The overlay + Close are wired by admin.js
     (data-modal-overlay / data-modal-close) and htmx handles footer fragment swaps. -->
{%- macro cellinner(c) -%}
{%- if c.badge %}<span class="badge {{ c.badge }}"><span class="dot"></span>{{ c.text }}</span>{% elif c.mono %}<span class="mono dim">{{ c.text }}</span>{% else %}{{ c.text }}{% endif -%}
{%- endmacro -%}
{%- macro render_cell(c) -%}
{%- if c.link %}<a class="cell-link" href="/admin/{{ c.link }}">{{ cellinner(c) }}</a>{% else %}{{ cellinner(c) }}{% endif -%}
{%- endmacro -%}
<div class="modal-overlay" data-modal-overlay>
  <div class="modal">
    <div class="modal-header">
      {% if header %}<div class="modal-avatar {{ header.avatar_color_key }}">{{ header.avatar_text }}</div>{% endif %}
      <div class="modal-heading">
        <div class="modal-name">{% if header %}{{ header.title }}{% else %}{{ title }}{% endif %}</div>
        {% if header and header.subtitle_mono %}<div class="modal-sub mono">{{ header.subtitle_mono }}</div>{% endif %}
      </div>
      <button type="button" class="modal-close" data-modal-close aria-label="Close">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </div>
    <div class="modal-body">
      {% if err %}<div class="empty">{{ err }}</div>{% endif %}
      {% if kpis %}<div class="kpi-grid">{% for k in kpis %}<div class="kpi"><div class="kpi-label">{{ k.label }}</div><div class="kpi-value">{{ k.value }}</div>{% if k.sub %}<div class="kpi-sub">{{ k.sub }}</div>{% endif %}</div>{% endfor %}</div>{% endif %}
      {% if table %}{% if table.rows %}<table class="table"><thead><tr>{% for c in table.columns %}<th>{{ c }}</th>{% endfor %}</tr></thead><tbody>{% for row in table.rows %}<tr>{% for cell in row %}<td>{{ render_cell(cell) }}</td>{% endfor %}</tr>{% endfor %}</tbody></table>{% else %}<div class="empty">No rows yet.</div>{% endif %}{% endif %}
      {% if cards %}<div class="card-grid">{% for c in cards.cards %}<div class="card"><div class="card-head"><div class="card-avatar {{ c.color_key }}">{{ c.icon_text }}</div><div class="card-meta"><div class="card-title">{{ c.title }}</div>{% if c.subtitle %}<div class="card-subtitle">{{ c.subtitle }}</div>{% endif %}</div>{% if c.badge %}<span class="badge {{ c.color_key }}">{{ c.badge }}</span>{% endif %}</div>{% if c.stats %}<div class="card-stats">{% for s in c.stats %}<div class="card-stat"><span class="stat-k">{{ s.label }}</span><span class="stat-v">{{ s.value }}</span></div>{% endfor %}</div>{% endif %}</div>{% endfor %}</div>{% endif %}
    </div>
    <div class="modal-footer">
      {% for m in modal_footer %}{% if m.separator %}{% elif m.href %}<a class="btn" href="/admin/{{ m.href }}"{% if m.hx_url %} hx-get="/admin/{{ m.hx_url }}" hx-target="#modal-root" hx-swap="innerHTML"{% endif %}>{{ m.label }}</a>{% else %}<span class="btn-ghost" style="opacity:.5;">{{ m.label }}</span>{% endif %}{% endfor %}
      <button type="button" class="btn-ghost" data-modal-close>Close</button>
    </div>
  </div>
</div>
