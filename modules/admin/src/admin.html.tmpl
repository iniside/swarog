<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>GameOps — Admin</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/admin/theme.css">
</head>
<body>
{%- macro cellinner(c) -%}
{%- if c.icon_text %}<span class="cell-icon-wrap"><span class="cell-avatar {{ c.icon_color_key }}">{{ c.icon_text }}</span><span class="cell-icon-label">{{ c.text }}</span></span>{% elif c.badge %}<span class="badge {{ c.badge }}"><span class="dot"></span>{{ c.text }}</span>{% elif c.mono %}<span class="mono dim">{{ c.text }}</span>{% else %}{{ c.text }}{% endif -%}
{%- endmacro -%}
{%- macro render_cell(c) -%}
{%- if c.link %}<a class="cell-link" href="/admin/{{ c.link }}">{{ cellinner(c) }}</a>{% else %}{{ cellinner(c) }}{% endif -%}
{%- endmacro -%}
{%- macro menu_icon(key) -%}
{%- if key == "edit" or key == "pen" %}<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z"/></svg>
{%- elif key == "delete" or key == "trash" %}<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M8 6V4h8v2"/><path d="M6 6l1 14h10l1-14"/></svg>
{%- elif key == "view" or key == "eye" %}<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7z"/><circle cx="12" cy="12" r="3"/></svg>
{%- elif key == "characters" or key == "users" %}<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 4-6 8-6s8 2 8 6"/></svg>
{%- elif key == "inventory" or key == "box" %}<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7l9-4 9 4-9 4-9-4z"/><path d="M3 7v10l9 4 9-4V7"/><path d="M12 11v10"/></svg>
{%- endif -%}
{%- endmacro -%}
{%- macro menu_items(menu) -%}
{%- for m in menu -%}
{%- if m.separator %}<div class="menu-sep"></div>
{%- elif m.href and not m.disabled %}<a class="menu-item{% if m.danger %} danger{% endif %}" href="/admin/{{ m.href }}"{% if m.hx_url %} hx-get="/admin/{{ m.hx_url }}" hx-target="#modal-root" hx-swap="innerHTML"{% endif %}>{{ menu_icon(m.icon) }}<span>{{ m.label }}</span></a>
{%- else %}<span class="menu-item disabled{% if m.danger %} danger{% endif %}">{{ menu_icon(m.icon) }}<span>{{ m.label }}</span></span>
{%- endif -%}
{%- endfor -%}
{%- endmacro -%}
{%- macro kebab(menu, mid) -%}
{%- if menu %}<div class="menu-wrap"><button type="button" class="kebab" data-menu="{{ mid }}" aria-label="Actions" aria-haspopup="true" aria-expanded="false"><svg width="15" height="15" viewBox="0 0 24 24" fill="#6b7180"><circle cx="5" cy="12" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="19" cy="12" r="1.6"/></svg></button><div class="menu" data-menu-panel="{{ mid }}" hidden>{{ menu_items(menu) }}</div></div>{% endif -%}
{%- endmacro -%}
<div class="app">

  <aside class="sidebar">
    <div class="brand">
      <div class="brand-logo">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10131a" stroke-width="2.2" stroke-linejoin="round"><path d="M12 3 21 8v8l-9 5-9-5V8z"/><path d="M12 3v18M3 8l9 5 9-5"/></svg>
      </div>
      <div>
        <div class="brand-title">GameOps</div>
        <div class="brand-sub">Backend Console</div>
      </div>
    </div>
    <nav class="nav">
      {% for g in groups %}
      <div class="nav-group">{{ g.section }}</div>
      {% for it in g.items %}<a class="nav-item{% if it.active %} active{% endif %}" href="/admin/{{ it.slug }}"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg><span>{{ it.label }}</span></a>{% endfor %}
      {% endfor %}
      <div class="nav-group">PLATFORM</div>
      <span class="nav-item muted">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M4 20V12M10 20V4M16 20V9M21 20H3"/></svg>
        <span>Analytics</span>
      </span>
      <span class="nav-item muted">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"><path d="M13 3 4 14h6l-1 7 9-11h-6z"/></svg>
        <span>Live Ops &amp; Events</span>
      </span>
      <span class="nav-item muted">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><ellipse cx="12" cy="6" rx="7" ry="3"/><path d="M5 6v6c0 1.7 3 3 7 3s7-1.3 7-3V6"/><path d="M5 12c0 1.7 3 3 7 3s7-1.3 7-3"/></svg>
        <span>Economy &amp; Store</span>
      </span>
      <span class="nav-item muted">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="4" y="11" width="4" height="9" rx="1"/><rect x="10" y="5" width="4" height="15" rx="1"/><rect x="16" y="14" width="4" height="6" rx="1"/></svg>
        <span>Leaderboards</span>
      </span>
      <span class="nav-item muted">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"><path d="M12 3 5 6v5c0 4 3 7 7 9 4-2 7-5 7-9V6z"/><path d="M9 12l2 2 4-4"/></svg>
        <span>Moderation</span>
      </span>
    </nav>
    <div class="sidebar-foot">
      <div class="avatar">{{ user.initials }}</div>
      <div style="flex:1;min-width:0;">
        <div class="foot-name">{{ user.name }}</div>
        <div class="foot-role">Backend Admin</div>
      </div>
      {% if csrf %}<form method="post" action="/admin/logout"><input type="hidden" name="_csrf" value="{{ csrf }}"><button type="submit" class="btn-ghost">Sign out</button></form>{% else %}<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6b7180" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>{% endif %}
    </div>
  </aside>

  <div class="main">
    <div class="header">
      <div style="min-width:0;">
        <div class="crumb">{{ crumb }}</div>
        <div class="title">{{ title }}</div>
      </div>
      <div class="spacer"></div>
      <div class="search">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#6b7180" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4"/></svg>
        <span style="flex:1;">Search players, matches, IDs…</span>
        <span class="kbd">⌘K</span>
      </div>
      <div class="env"><span class="pulse"></span>{{ env }}</div>
      <div class="hbtn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.7 21a2 2 0 0 1-3.4 0"/></svg>
        <span class="bell-badge">4</span>
      </div>
      <div class="avatar">{{ user.initials }}</div>
    </div>

    <div class="content">
      <div class="stack">
        {% if page %}
          {% if back or page.header %}<div class="context-header">{% if back %}<a class="back-chip" href="{{ back.href }}"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>{{ back.label }}</a>{% endif %}{% if page.header %}<div class="ctx-avatar {{ page.header.avatar_color_key }}">{{ page.header.avatar_text }}</div><div class="ctx-meta"><div class="ctx-title">{{ page.header.title }}</div>{% if page.header.subtitle_mono %}<div class="ctx-subtitle mono">{{ page.header.subtitle_mono }}</div>{% endif %}</div>{% if page.header.right_note %}<div class="ctx-note">{{ page.header.right_note }}</div>{% endif %}{% endif %}</div>{% endif %}
          {% if page.err %}<div class="panel"><div class="empty">{{ page.err }}</div></div>
          {% else %}
            {% if page.reveal %}<div class="panel"><div class="panel-title">Generated — shown once</div>{% for r in page.reveal %}<div class="form-row"><label>{{ r.label }}</label><input type="text" class="mono" name="reveal_{{ loop.index }}" value="{{ r.value }}" readonly></div>{% endfor %}<div class="empty">Copy now — these values are not stored and cannot be shown again.</div></div>{% endif %}
            {% if page.kpis %}<div class="kpi-grid">{% for k in page.kpis %}<div class="kpi"><div class="kpi-label">{{ k.label }}</div><div class="kpi-value">{{ k.value }}</div>{% if k.sub %}<div class="kpi-sub">{{ k.sub }}</div>{% endif %}</div>{% endfor %}</div>{% endif %}
            {% if page.table %}<div class="panel"><div class="panel-title">{{ page.title }}</div>{% if page.table.rows %}<table class="table"><thead><tr>{% for c in page.table.columns %}<th>{{ c }}</th>{% endfor %}{% if page.row_menus %}<th></th>{% endif %}</tr></thead><tbody>{% for row in page.table.rows %}<tr>{% for cell in row %}<td>{{ render_cell(cell) }}</td>{% endfor %}{% if page.row_menus %}<td class="row-menu">{{ kebab(page.row_menus[loop.index0], "r" ~ loop.index0) }}</td>{% endif %}</tr>{% endfor %}</tbody></table>{% else %}<div class="empty">No rows yet.</div>{% endif %}</div>{% endif %}
            {% if page.cards %}<div class="card-grid">{% for c in page.cards.cards %}<div class="card"><div class="card-head"><div class="card-avatar {{ c.color_key }}">{{ c.icon_text }}</div><div class="card-meta"><div class="card-title">{{ c.title }}</div>{% if c.subtitle %}<div class="card-subtitle">{{ c.subtitle }}</div>{% endif %}</div>{% if c.badge %}<span class="badge {{ c.color_key }}">{{ c.badge }}</span>{% endif %}{{ kebab(c.menu, "c" ~ loop.index0) }}</div>{% if c.stats %}<div class="card-stats">{% for s in c.stats %}<div class="card-stat"><span class="stat-k">{{ s.label }}</span><span class="stat-v">{{ s.value }}</span></div>{% endfor %}</div>{% endif %}</div>{% endfor %}</div>{% endif %}
            {% if page.form %}<div class="panel"><div class="panel-title">Edit</div><form method="post" action="{{ page.form.action }}">{% if csrf %}<input type="hidden" name="_csrf" value="{{ csrf }}">{% endif %}{% for h in page.form.hidden %}<input type="hidden" name="{{ h.name }}" value="{{ h.value }}">{% endfor %}{% for f in page.form.fields %}<div class="form-row"><label>{{ f.label }}</label>{% if f.kind == "Select" %}<select name="{{ f.name }}">{% for o in f.options %}<option value="{{ o.value }}"{% if o.checked %} selected{% endif %}>{{ o.label }}</option>{% endfor %}</select>{% elif f.kind == "CheckboxGroup" %}<div class="checkbox-group">{% for o in f.options %}<label class="checkbox"><input type="checkbox" name="{{ f.name }}" value="{{ o.value }}"{% if o.checked %} checked{% endif %}> {{ o.label }}</label>{% endfor %}</div>{% else %}<input type="text" name="{{ f.name }}" value="{{ f.value }}">{% endif %}</div>{% endfor %}<button type="submit" class="btn">Save</button></form></div>{% endif %}
          {% endif %}
        {% else %}
          <div class="panel"><div class="empty">No sections contributed yet.</div></div>
        {% endif %}
      </div>
    </div>
  </div>
</div>
<div id="modal-root"></div>
<script src="/admin/htmx.min.js" defer></script>
<script src="/admin/admin.js" defer></script>
</body>
</html>
