<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>GameOps — Admin</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/admin/theme.css">
</head>
<body>
{%- macro cellinner(c) -%}
{%- if c.badge %}<span class="badge {{ c.badge }}"><span class="dot"></span>{{ c.text }}</span>{% elif c.mono %}<span class="mono dim">{{ c.text }}</span>{% else %}{{ c.text }}{% endif -%}
{%- endmacro -%}
{%- macro render_cell(c) -%}
{%- if c.link %}<a class="cell-link" href="/admin/{{ c.link }}">{{ cellinner(c) }}</a>{% else %}{{ cellinner(c) }}{% endif -%}
{%- endmacro -%}
<div class="app">

  <aside class="sidebar">
    <div class="brand">
      <div class="brand-logo">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10131a" stroke-width="2.2" stroke-linejoin="round"><path d="M12 3 21 8v8l-9 5-9-5V8z"/><path d="M12 3v18M3 8l9 5 9-5"/></svg>
      </div>
      <div>
        <div class="brand-title">GameOps</div>
        <div class="brand-sub">Backend Console</div>
      </div>
    </div>
    <nav class="nav">
      {% for g in groups %}
      <div class="nav-group">{{ g.section }}</div>
      {% for it in g.items %}<a class="nav-item{% if it.active %} active{% endif %}" href="/admin/{{ it.slug }}"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg><span>{{ it.label }}</span></a>{% endfor %}
      {% endfor %}
      <div class="nav-group">COMING SOON</div>
      <span class="nav-item muted">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M4 20V12M10 20V4M16 20V9M21 20H3"/></svg>
        <span>Analytics</span>
      </span>
      <span class="nav-item muted">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"><path d="M13 3 4 14h6l-1 7 9-11h-6z"/></svg>
        <span>Live Ops &amp; Events</span>
      </span>
      <span class="nav-item muted">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><ellipse cx="12" cy="6" rx="7" ry="3"/><path d="M5 6v6c0 1.7 3 3 7 3s7-1.3 7-3V6"/><path d="M5 12c0 1.7 3 3 7 3s7-1.3 7-3"/></svg>
        <span>Economy &amp; Store</span>
      </span>
      <span class="nav-item muted">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="4" width="18" height="7" rx="1.5"/><rect x="3" y="13" width="18" height="7" rx="1.5"/><circle cx="7" cy="7.5" r="0.9" fill="currentColor" stroke="none"/><circle cx="7" cy="16.5" r="0.9" fill="currentColor" stroke="none"/></svg>
        <span>Matchmaking &amp; Servers</span>
      </span>
      <span class="nav-item muted">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="4" y="11" width="4" height="9" rx="1"/><rect x="10" y="5" width="4" height="15" rx="1"/><rect x="16" y="14" width="4" height="6" rx="1"/></svg>
        <span>Leaderboards</span>
      </span>
      <span class="nav-item muted">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"><path d="M12 3 5 6v5c0 4 3 7 7 9 4-2 7-5 7-9V6z"/><path d="M9 12l2 2 4-4"/></svg>
        <span>Moderation</span>
      </span>
      <span class="nav-item muted">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"><path d="M5 4v16"/><path d="M5 5h12l-2.5 3.5L17 12H5"/></svg>
        <span>Game Config &amp; Flags</span>
      </span>
    </nav>
    <div class="sidebar-foot">
      <div class="avatar">{{ user.initials }}</div>
      <div style="flex:1;min-width:0;">
        <div class="foot-name">{{ user.name }}</div>
        <div class="foot-role">Backend Admin</div>
      </div>
      {% if csrf %}<form method="post" action="/admin/logout"><input type="hidden" name="_csrf" value="{{ csrf }}"><button type="submit" class="btn">Sign out</button></form>{% else %}<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6b7180" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>{% endif %}
    </div>
  </aside>

  <div class="main">
    <div class="header">
      <div>
        <div class="crumb">{{ crumb }}</div>
        <div class="title">{{ title }}</div>
      </div>
      <div class="spacer"></div>
      <div class="search">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#6b7180" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4"/></svg>
        <span>Search players, matches, IDs…</span>
        <span class="kbd">⌘K</span>
      </div>
      <div class="env"><span class="pulse" style="width:7px;height:7px;border-radius:999px;background:var(--green);"></span>{{ env }}</div>
      <div class="hbtn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.7 21a2 2 0 0 1-3.4 0"/></svg>
      </div>
      <div class="avatar">{{ user.initials }}</div>
    </div>

    <div class="content">
      <div class="stack">
        {% if page %}
          {% if page.err %}<div class="panel"><div class="empty">{{ page.err }}</div></div>
          {% else %}
            {% if page.kpis %}<div class="kpi-grid">{% for k in page.kpis %}<div class="kpi"><div class="kpi-label">{{ k.label }}</div><div class="kpi-value">{{ k.value }}</div>{% if k.sub %}<div class="kpi-sub">{{ k.sub }}</div>{% endif %}</div>{% endfor %}</div>{% endif %}
            {% if page.table %}<div class="panel"><div class="panel-title">{{ page.title }}</div>{% if page.table.rows %}<table class="table"><thead><tr>{% for c in page.table.columns %}<th>{{ c }}</th>{% endfor %}</tr></thead><tbody>{% for row in page.table.rows %}<tr>{% for cell in row %}<td>{{ render_cell(cell) }}</td>{% endfor %}</tr>{% endfor %}</tbody></table>{% else %}<div class="empty">No rows yet.</div>{% endif %}</div>{% endif %}
            {% if page.form %}<div class="panel"><div class="panel-title">Edit</div><form method="post" action="{{ page.form.action }}">{% if csrf %}<input type="hidden" name="_csrf" value="{{ csrf }}">{% endif %}{% for h in page.form.hidden %}<input type="hidden" name="{{ h.name }}" value="{{ h.value }}">{% endfor %}{% for f in page.form.fields %}<div class="form-row"><label>{{ f.label }}</label><input type="text" name="{{ f.name }}" value="{{ f.value }}"></div>{% endfor %}<button type="submit" class="btn">Save</button></form></div>{% endif %}
          {% endif %}
        {% else %}
          <div class="panel"><div class="empty">No sections contributed yet.</div></div>
        {% endif %}
      </div>
    </div>
  </div>
</div>
</body>
</html>
